rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isAdmin() {
      return request.auth != null
        && request.auth.token.email == 'sonkh@rubycell.co.kr';
    }

    function userUpdateAllowed() {
      return !request.resource.data.diff(resource.data).affectedKeys().hasAny(['adminNote']);
    }

    match /users/{userId} {
      allow read: if request.auth != null && (request.auth.uid == userId || isAdmin());
      allow create: if request.auth != null && request.auth.uid == userId;
      allow update: if isAdmin()
        || (request.auth != null && request.auth.uid == userId && userUpdateAllowed());
      allow delete: if isAdmin();

      match /{document=**} {
        allow read, write, delete: if request.auth != null && (request.auth.uid == userId || isAdmin());
      }
    }

    match /activationRequests/{requestId} {
      allow read: if isAdmin()
        || (request.auth != null && resource.data.uid == request.auth.uid);
      allow create: if request.auth != null
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.status == 'pending'
        && request.resource.data.type == 'bank_transfer'
        && request.resource.data.email == request.auth.token.email;
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    match /coachRegistry/{phoneKey} {
      allow get: if request.auth != null;
      allow list: if isAdmin();
      allow create: if request.auth != null
        && request.auth.uid == request.resource.data.uid
        && request.resource.data.phone == phoneKey
        && !exists(/databases/$(database)/documents/coachRegistry/$(phoneKey));
      allow update, delete: if isAdmin();
    }
  }
}
